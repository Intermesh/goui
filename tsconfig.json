{
  "compilerOptions": {
    "strict" : true,
    "target": "ES2022",
    "sourceMap": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "isolatedModules": true, // important for tree shaking in esbuild
    "module":"preserve",
    "outDir": "./dist",
    "tsBuildInfoFile": "./dist/tsconfig.tsbuildinfo",
    "rootDir": "./script",
    "declaration": true,
    "declarationMap": true,
    "composite": true
  },

  "include": [
    "./script"
  ]
  
}
